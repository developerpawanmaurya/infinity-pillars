PORT=3001
DATABASE_PATH=./data/bookings.db

# Optional: required to send confirmation emails (bookings still save without SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM="Infinity Pillars <noreply@example.com>"

# Optional: protect GET /api/bookings for admin use
ADMIN_API_KEY=change-me
