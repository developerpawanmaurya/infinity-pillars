<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /

	# Explicitly route /blog and /blog/* to the React SPA BEFORE Apache checks
	# for a physical directory (prevents the /blog → /blog/ redirect that
	# exposes a WordPress install in the /blog/ folder).
	RewriteRule ^blog$ /index.html [L]
	RewriteRule ^blog/.*$ /index.html [L]

	# Standard SPA fallback for all other routes
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
	Header set X-Powered-By "Hostinger Horizons"

	# Cache everything on CDN by default
	Header set Cache-Control "public, s-maxage=604800, max-age=0"

	# Cache in browser all assets
	<If "%{REQUEST_URI} =~ m#^/assets/.*$#">
		Header set Cache-Control "public, max-age=604800"
	</If>
</IfModule>
